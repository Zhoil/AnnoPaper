# =============================================
# 大模型 API 配置模板
# 使用方法：
#   1. 复制本文件并重命名为 .env
#   2. 填入你自己的 API 密钥
#   3. .env 文件已被 git 忽略，不会上传
#
# 扩展新 provider：
#   1. 在此添加 NEWNAME_API_KEY / _API_URL / _MODEL / _FILE_MODEL 等
#   2. 在 llm_service.py 的 PROVIDERS 列表中添加 'newname'
# =============================================

# ── DeepSeek ─────────────────────────────────
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MODELS=deepseek-v4-pro,deepseek-v4-flash
DEEPSEEK_TIMEOUT=120
DEEPSEEK_DISPLAY_NAME=DeepSeek-V4-Pro
# 思考模式：enabled/disabled（默认 enabled）
DEEPSEEK_THINKING=enabled
# 思考强度：high/max（默认 high）
DEEPSEEK_REASONING_EFFORT=high

# ── Qwen（阿里云百炼 DashScope）──────────────
# 获取地址: https://bailian.console.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_MODEL=qwen3.6-plus
QWEN_FILE_MODEL=qwen-long
QWEN_TIMEOUT=60
QWEN_DISPLAY_NAME=Qwen3.6-Plus

# ── PipeLLM（统一 OpenAI 兼容网关）──────────────
# 获取地址: 向服务商获取 API Key。注意部分网关（如 lb.ha5fun.cn）对 gpt-5.x 必须 stream=true
PIPELLM_API_KEY=your_pipellm_api_key_here
PIPELLM_API_URL=https://lb.ha5fun.cn/v1/chat/completions
PIPELLM_MODEL=gpt-5.5
PIPELLM_MODELS=gpt-5.5,claude-sonnet-4-6
PIPELLM_TIMEOUT=120
PIPELLM_DISPLAY_NAME=PipeLLM
PIPELLM_SUPPORTS_JSON=false
PIPELLM_SUPPORTS_FILE_UPLOAD=false
# 启用流式（SSE）调用，兼容 gpt-5.x 必须 stream=true 的网关行为
PIPELLM_SUPPORTS_STREAM=true
# stream 白名单：仅列出的模型用 stream（支持前缀匹配），其余走 non-stream
PIPELLM_STREAM_MODELS=gpt-5,gpt-4
# 网关负载类错误的 stream 重试次数（失败后自动降级一次 non-stream）
PIPELLM_STREAM_RETRY_MAX=3
# non-stream 重试次数
PIPELLM_NONSTREAM_RETRY_MAX=3

# ── 各 provider 文件上传能力 ──────────────────
QWEN_SUPPORTS_FILE_UPLOAD=true
DEEPSEEK_SUPPORTS_FILE_UPLOAD=false

# ── 对话功能使用的 provider ──────────────────
CHAT_PROVIDER=deepseek
